{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://immortals/contracts/event.v1.json",
  "title": "event/v1",
  "description": "An immutable, append-only event. The orchestrator's state is a fold over the event log.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "event_id", "task_id", "ts", "type"],
  "properties": {
    "schema": { "const": "event/v1" },
    "event_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "ts": { "type": "string", "minLength": 1, "description": "ISO-8601 timestamp." },
    "type": {
      "enum": [
        "plan_created",
        "plan_validated",
        "node_started",
        "node_completed",
        "node_failed",
        "artifact_written",
        "approval_requested",
        "approval_granted",
        "escalation",
        "decision",
        "run_completed"
      ]
    },
    "node_id": { "type": "string" },
    "agent": { "type": "string" },
    "payload": { "type": "object" }
  }
}
